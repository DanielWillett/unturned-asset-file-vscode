{
    "$schema": "./Asset Spec Schema.json",
    "Type": "SDG.Unturned.ItemFisherAsset, Assembly-CSharp",
    "DisplayName": "Fisher Item (Rod)",
    "Parent": "SDG.Unturned.ItemAsset, Assembly-CSharp",
    "Docs": "https://docs.smartlydressedgames.com/en/stable/items/fisher-asset.html",
    "Properties":
    [
        {
            "Key": "Reward_ID",
            "Type":
            {
                "Type": "LegacyAssetReference",
                "AssetType": "SDG.Unturned.SpawnAsset, Assembly-CSharp"
            },
            "DefaultValue": 0,
            "Description": "Spawn table used to reward items when a fish is caught.",
            "Docs": "https://docs.smartlydressedgames.com/en/stable/items/fisher-asset.html#fisher-asset-properties",
            "Variable": "rewardID",
            "Required": true
        },
        {
            "Key": "Reward_Experience_Min",
            "Type": "Int32",
            "DefaultValue": 3,
            "Maximum": "@Reward_Experience_Max",
            "Description": "Experience to give when a fish is caught. A random value is chosen between @Reward_Experience_Min and @Reward_Experience_Max.",
            "Docs": "https://docs.smartlydressedgames.com/en/stable/items/fisher-asset.html#fisher-asset-properties",
            "Variable": "rewardExperienceMin",
            "InclusiveWith": [ "Reward_Experience_Min" ]
        },
        {
            "Key": "Reward_Experience_Max",
            "Type": "Int32",
            "DefaultValue": 3,
            "Minimum": "@Reward_Experience_Min",
            "Description": "Experience to give when a fish is caught. A random value is chosen between @Reward_Experience_Min and @Reward_Experience_Max.",
            "Docs": "https://docs.smartlydressedgames.com/en/stable/items/fisher-asset.html#fisher-asset-properties",
            "Variable": "rewardExperienceMax"
        },
        {
            "Key": "Quest_Rewards",
            "Type":
            {
                "Type": "List",
                "ElementType": "SDG.Unturned.INPCReward, Assembly-CSharp",
                "Mode": "LegacyList, ModernList"
            },
            "DefaultValue": [ ],
            "Description": "Rewards applied when catching a fish.",
            "Docs": "https://docs.smartlydressedgames.com/en/stable/items/fisher-asset.html#fisher-asset-properties",
            "Variable": "rewardsList"
        },
        {
            "Key": "Fish_Bite_Interval_Multiplier",
            "Type": "Float32",
            "DefaultValue": 1.0,
            "Minimum": 0.0,
            "Description": "Multiplier for interval before a fish takes the bait.",
            "Docs": "https://docs.smartlydressedgames.com/en/stable/items/fisher-asset.html#fisher-asset-properties",
            "Variable": "FishBiteIntervalMultiplier",
            "Version": "3.26.2.0"
        },
        {
            "Key": "Fishing_Reward_Mode",
            "Type": "SDG.Unturned.EFishingRewardMode, Assembly-CSharp",
            "DefaultValue": "Rod",
            "Description": "Where item rewards are drawn from. Defaults to 'Rod' for backwards-compatability but should usually be changed to 'WaterVolumes'.",
            "Docs": "https://docs.smartlydressedgames.com/en/stable/items/fisher-asset.html#fisher-asset-properties",
            "Variable": "FishingRewardMode",
            "Version": "3.26.2.0"
        },
        {
            "Key": "CatchChallenge_Enabled",
            "Type": "Boolean",
            "DefaultValue": false,
            "Description": "Whether or not the player must complete a challenge when fish takes the bait before catching. Defaults to false for backwards-compatability but should usually be changed to true.",
            "Docs": "https://docs.smartlydressedgames.com/en/stable/items/fisher-asset.html#fisher-asset-properties",
            "Variable": "EnableCatchChallenge",
            "Version": "3.26.2.0"
        },
        {
            "Key": "CatchChallenge_CursorSize",
            "Type": "Float32",
            "DefaultValue": 0.2,
            "MinimumExclusive": 0.0,
            "Description": "Percentage (0-1) of the fishing window taken up by the cursor.",
            "Docs": "https://docs.smartlydressedgames.com/en/stable/items/fisher-asset.html#fisher-asset-properties",
            "Variable": "CatchChallengeCursorSize",
            "Version": "3.26.2.0"
        },
        {
            "Key": "CatchChallenge_Gravity",
            "Type": "Float32",
            "DefaultValue": 1.0,
            "MinimumExclusive": 0.0,
            "Description": "Downward acceleration while input is not held.",
            "Docs": "https://docs.smartlydressedgames.com/en/stable/items/fisher-asset.html#fisher-asset-properties",
            "Variable": "CatchChallengeGravity",
            "Version": "3.26.2.0"
        },
        {
            "Key": "CatchChallenge_Acceleration",
            "Type": "Float32",
            "DefaultValue": 1.0,
            "MinimumExclusive": 0.0,
            "Description": "Upward acceleration while input is held.",
            "Docs": "https://docs.smartlydressedgames.com/en/stable/items/fisher-asset.html#fisher-asset-properties",
            "Variable": "CatchChallengeAcceleration",
            "Version": "3.26.2.0"
        },
        {
            "Key": "CatchChallenge_UpperRestitution",
            "Type": "Float32",
            "DefaultValue": 0.5,
            "Minimum": 0.0,
            "Description": "How much velocity to preserve when bouncing off the top.",
            "Docs": "https://docs.smartlydressedgames.com/en/stable/items/fisher-asset.html#fisher-asset-properties",
            "Variable": "CatchChallengeUpperRestitution",
            "Version": "3.26.2.0"
        },
        {
            "Key": "CatchChallenge_LowerRestitution",
            "Type": "Float32",
            "DefaultValue": 0.5,
            "Minimum": 0.0,
            "Description": "How much velocity to preserve when bouncing off the bottom.",
            "Docs": "https://docs.smartlydressedgames.com/en/stable/items/fisher-asset.html#fisher-asset-properties",
            "Variable": "CatchChallengeLowerRestitution",
            "Version": "3.26.2.0"
        },
        {
            "Key": "CatchChallenge_CaptureSpeed",
            "Type": "Float32",
            "DefaultValue": 1.0,
            "MinimumExclusive": 0.0,
            "Description": "Multiplier for how quickly item is caught while within cursor.",
            "Docs": "https://docs.smartlydressedgames.com/en/stable/items/fisher-asset.html#fisher-asset-properties",
            "Variable": "CatchChallengeCaptureSpeedMultiplier",
            "Version": "3.26.2.0"
        },
        {
            "Key": "CatchChallenge_EscapeSpeed",
            "Type": "Float32",
            "DefaultValue": 1.0,
            "Minimum": 0.0,
            "Description": "Multiplier for how quickly the player loses the fish while it's outside the cursor.",
            "Docs": "https://docs.smartlydressedgames.com/en/stable/items/fisher-asset.html#fisher-asset-properties",
            "Variable": "CatchChallengeEscapeSpeedMultiplier",
            "Version": "3.26.2.0"
        }
    ],
    "Types":
    [
        {
            "Type": "SDG.Unturned.EFishingRewardMode, Assembly-CSharp",
            "DisplayName": "Fishing Reward Mode",
            "Docs": "https://docs.smartlydressedgames.com/en/stable/items/fisher-asset.html#fisher-asset-properties",
            "Version": "3.26.2.0",
            "Values":
            [
                {
                    "Value": "Rod",
                    "Description": "Fishing rod itself defines rewards. Ignore per-volume rewards."
                },
                {
                    "Value": "WaterVolumes",
                    "Description": "Use per-volume (or per-level if volume unspecified) rewards. If level doesn't support volume rewards, fallback to 'Rod' rewards."
                }
            ]
        }
    ],
    "BundleAssets":
    [
        {
            "Key": "Cast",
            "Type": "UnityEngine.AudioClip, UnityEngine.AudioModule",
            "Description": "The sound played when the fishing rod is casted.",
            "Variable": "cast",
            "Required": true
        },
        {
            "Key": "Reel",
            "Type": "UnityEngine.AudioClip, UnityEngine.AudioModule",
            "Description": "The sound played when reeling the fishing rod in.",
            "Variable": "reel",
            "Required": true
        },
        {
            "Key": "Tug",
            "Type": "UnityEngine.AudioClip, UnityEngine.AudioModule",
            "Description": "The sound played when tugging on the fishing rod.",
            "Variable": "tug",
            "Required": true
        }
    ]
}